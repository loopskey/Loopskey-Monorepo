// ================== Roadmap ====================
enum RoadmapStatus {
  DRAFT
  ARCHIVED
  PUBLISHED
}

enum RoadmapEnrollmentStatus {
  ACTIVE
  COMPLETED
  UNENROLLED
}

model Roadmap {
  id   String @id @default(cuid())
  slug String @unique

  title       String
  description String
  imageUrl    String?

  category CourseCategory?
  level    CourseLevel     @default(ALL_LEVELS)
  status   RoadmapStatus   @default(PUBLISHED)

  phases      RoadmapPhase[]
  enrollments RoadmapEnrollment[]

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  @@index([status])
  @@index([category])
  @@index([title])
}

model RoadmapPhase {
  id String @id @default(cuid())

  roadmapId String
  roadmap   Roadmap @relation(fields: [roadmapId], references: [id], onDelete: Cascade)

  title       String
  description String?
  order       Int

  steps RoadmapStep[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([roadmapId, order])
  @@index([roadmapId])
}

model RoadmapStep {
  id String @id @default(cuid())

  phaseId String
  phase   RoadmapPhase @relation(fields: [phaseId], references: [id], onDelete: Cascade)

  title       String
  description String?
  order       Int

  contentType ContentType?
  contentId   String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([phaseId, order])
  @@index([phaseId])
  @@index([contentType, contentId])
}

model RoadmapEnrollment {
  id String @id @default(cuid())

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  roadmapId String
  roadmap   Roadmap @relation(fields: [roadmapId], references: [id], onDelete: Cascade)

  progress Int                     @default(0)
  status   RoadmapEnrollmentStatus @default(ACTIVE)

  enrolledAt  DateTime  @default(now())
  completedAt DateTime?
  updatedAt   DateTime  @updatedAt

  @@unique([userId, roadmapId])
  @@index([userId])
  @@index([roadmapId])
  @@index([status])
}

// ================ Organization ==================
enum OrganizationMemberStatus {
  ACTIVE
  INACTIVE
}

enum ComplianceCycle {
  ANNUAL
  BIANNUAL
  QUARTERLY
}

enum AssignmentType {
  HARD
  SOFT
}

enum AssignmentStatus {
  ACTIVE
  ARCHIVED
  COMPLETED
}

enum AssignmentTargetKind {
  ALL
  ROLE
  MEMBER
  DEPARTMENT
}

model Organization {
  id String @id @default(cuid())

  ownerId String @unique
  owner   User   @relation("OrganizationOwner", fields: [ownerId], references: [id], onDelete: Cascade)

  name          String
  logoUrl       String?
  description   String?
  country       String?
  industry      String?
  website       String?
  settings      OrganizationSettings?
  departments   OrganizationDepartment[]
  members       OrganizationMember[]
  cpdCategories OrganizationCPDCategory[]
  assignments   OrganizationAssignment[]

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  @@index([ownerId])
  @@index([name])
}

model OrganizationSettings {
  id String @id @default(cuid())

  organizationId String       @unique
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  complianceCycle  ComplianceCycle @default(ANNUAL)
  minimumPdu       Float           @default(60)
  strictCompliance Boolean         @default(false)

  complianceAlerts        Boolean @default(true)
  assignmentNotifications Boolean @default(true)
  weeklySummaryReport     Boolean @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model OrganizationDepartment {
  id String @id @default(cuid())

  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  title       String
  description String?
  isActive    Boolean @default(true)

  members OrganizationMember[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([organizationId, title])
  @@index([organizationId])
}

model OrganizationMember {
  id String @id @default(cuid())

  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  departmentId String?
  department   OrganizationDepartment? @relation(fields: [departmentId], references: [id], onDelete: SetNull)

  jobRole String?
  status  OrganizationMemberStatus @default(ACTIVE)

  completedLearning Int   @default(0)
  pdus              Float @default(0)
  compliance        Float @default(0)

  joinedAt      DateTime  @default(now())
  deactivatedAt DateTime?
  notes         String?

  assignments OrganizationAssignmentRecipient[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([organizationId, userId])
  @@index([organizationId])
  @@index([userId])
  @@index([departmentId])
  @@index([status])
  @@index([compliance])
}

model OrganizationCPDCategory {
  id String @id @default(cuid())

  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  category      PDUCategory
  title         String
  description   String?
  requiredHours Float
  isActive      Boolean     @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([organizationId, category])
  @@index([organizationId])
  @@index([category])
  @@index([isActive])
}

model OrganizationAssignment {
  id String @id @default(cuid())

  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  createdById String
  createdBy   User   @relation("CreatedOrgAssignments", fields: [createdById], references: [id], onDelete: Cascade)

  courseId String?
  course   Course? @relation(fields: [courseId], references: [id], onDelete: SetNull)

  eventId String?
  event   Event?  @relation(fields: [eventId], references: [id], onDelete: SetNull)

  title       String
  description String?

  type   AssignmentType   @default(SOFT)
  status AssignmentStatus @default(ACTIVE)

  targetKind     AssignmentTargetKind @default(ALL)
  departmentId   String?
  targetRole     String?
  targetMemberId String?

  dueDate DateTime?

  recipients OrganizationAssignmentRecipient[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([organizationId])
  @@index([courseId])
  @@index([eventId])
  @@index([status])
  @@index([type])
  @@index([dueDate])
  @@index([createdAt])
}

model OrganizationAssignmentRecipient {
  id String @id @default(cuid())

  assignmentId String
  assignment   OrganizationAssignment @relation(fields: [assignmentId], references: [id], onDelete: Cascade)

  memberId String
  member   OrganizationMember @relation(fields: [memberId], references: [id], onDelete: Cascade)

  completedAt DateTime?
  progress    Int       @default(0)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([assignmentId, memberId])
  @@index([assignmentId])
  @@index([memberId])
  @@index([completedAt])
}

