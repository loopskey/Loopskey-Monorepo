generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  ADMIN
  PROVIDER
  PROFESSIONAL
  ORGANIZATION
}

enum UserStatus {
  ACTIVE
  PENDING
  DELETED
  DISABLED
}

enum OtpPurpose {
  SIGNUP
  CHANGE_EMAIL
  RESET_PASSWORD
  EMAIL_VERIFICATION
  ORGANIZATION_ACTIVATION
}

enum NotificationDeliveryStatus {
  NOT_REQUESTED
  PENDING
  SENT
  FAILED
}

enum AuthProvider {
  EMAIL
  GOOGLE
  LINKEDIN
  FACEBOOK
}

enum SessionStatus {
  ACTIVE
  REVOKED
  EXPIRED
}

// =============== User ================
model User {
  id String @id @default(cuid())

  email String? @unique
  phone String? @unique

  passwordHash String?

  firstName String?
  lastName  String?
  fullName  String?

  avatarUrl        String?
  avatarStorageKey String?
  bio              String?

  role   Role       @default(PROFESSIONAL)
  status UserStatus @default(PENDING)

  forcePasswordChange Boolean @default(false)

  emailVerifiedAt DateTime?
  phoneVerifiedAt DateTime?

  passwordChangedAt DateTime?

  lastLoginAt DateTime?

  authAccounts AuthAccount[]
  sessions     AuthSession[]
  otpCodes     OtpCode[]

  professionalProfile ProfessionalProfile?
  providerProfile     ProviderProfile?
  organizationProfile OrganizationProfile?

  createdAt                  DateTime                    @default(now())
  updatedAt                  DateTime                    @updatedAt
  deletedAt                  DateTime?
  organizationAccessRequests OrganizationAccessRequest[]
  courses                    Course[]
  createdCourses             Course[]                    @relation("ProviderCourses")
  events                     Event[]
  createdEvents              Event[]                     @relation("ProviderEvents")
  eventRegistrations         EventRegistration[]         @relation("UserEventRegistrations")
  createdPodcasts            Podcast[]                   @relation("ProviderPodcasts")
  createdYouTubeChannels     YouTubeChannel[]            @relation("ProviderYouTubeChannels")
  youTubeChannels            YouTubeChannel[]
  wishlistItems              WishlistItem[]
  contentEnrollments         ContentEnrollment[]
  contentReviews             ContentReview[]
  carts                      Cart[]
  providerSettings           ProviderSettings?

  professionalSettings   ProfessionalSettings?
  pduActivities          PDUActivity[]
  pduActivityFiles       PDUActivityFile[]
  pduTargets             PDUTarget[]
  certificates           Certificate[]
  professionalCredential ProfessionalCredential[]
  payments               Payment[]
  roadmapEnrollments     RoadmapEnrollment[]

  ownedOrganization       Organization?            @relation("OrganizationOwner")
  organizationMemberships OrganizationMember[]
  createdOrgAssignments   OrganizationAssignment[] @relation("CreatedOrgAssignments")

  promotionRequests          EventPromotionRequest[]
  reviewedPromotionRequests  EventPromotionRequest[]    @relation("ReviewedPromotionRequests")
  auditLogs                  AuditLog[]                 @relation("AuditActor")
  externalLearningActivities ExternalLearningActivity[]
  calendarEvents             CalendarEvent[]
  cpdPlans                   CPDPlan[]

  @@index([role])
  @@index([status])
  @@index([createdAt])
}

// ================= Auth =================
model AuthAccount {
  id String @id @default(cuid())

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  provider AuthProvider @default(EMAIL)

  providerUserId String?
  providerEmail  String?

  accessToken  String?
  refreshToken String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([provider, providerUserId])
  @@index([userId])
}

model AuthSession {
  id String @id @default(cuid())

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  refreshTokenHash String

  status SessionStatus @default(ACTIVE)

  ipAddress String?
  userAgent String?

  expiresAt DateTime
  revokedAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
  @@index([status])
  @@index([expiresAt])
}

model OtpCode {
  id String @id @default(cuid())

  userId String?
  user   User?   @relation(fields: [userId], references: [id], onDelete: Cascade)

  destination String
  codeHash    String

  purpose OtpPurpose

  expiresAt  DateTime
  consumedAt DateTime?

  attempts    Int @default(0)
  maxAttempts Int @default(5)

  resendAfter DateTime?

  createdAt DateTime @default(now())

  @@index([userId])
  @@index([destination])
  @@index([purpose])
  @@index([expiresAt])
}

model PendingRegistration {
  id String @id @default(cuid())

  email        String @unique
  fullName     String
  passwordHash String
  role         Role

  otpCodeHash  String
  otpExpiresAt DateTime

  attempts    Int @default(0)
  maxAttempts Int @default(5)

  resendAfter DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([email])
  @@index([role])
  @@index([otpExpiresAt])
}

// ================= Profile =================
enum ProfessionalIndustry {
  TECHNOLOGY
  HEALTHCARE
  FINANCE
  EDUCATION
  ENGINEERING
  CONSTRUCTION
  LEGAL
  MARKETING
  MANUFACTURING
  PUBLIC_SECTOR
  NON_PROFIT
  OTHER
}

enum ExperienceRange {
  LESS_THAN_ONE_YEAR
  ONE_TO_TWO_YEARS
  THREE_TO_FIVE_YEARS
  SIX_TO_TEN_YEARS
  ELEVEN_TO_FIFTEEN_YEARS
  SIXTEEN_PLUS_YEARS
}

enum SkillLevel {
  BEGINNER
  INTERMEDIATE
  ADVANCED
  EXPERT
}

enum LearningFormat {
  COURSE
  WEBINAR
  WORKSHOP
  VIDEO
  PODCAST
  ARTICLE
}

enum LearningTimeCommitment {
  LESS_THAN_ONE_HOUR
  ONE_TO_THREE_HOURS
  FOUR_TO_SIX_HOURS
  SEVEN_TO_TEN_HOURS
  MORE_THAN_TEN_HOURS
}

enum LearningBudgetPreference {
  FREE_ONLY
  MIXED_FREE_AND_PAID
  PREMIUM
  EMPLOYER_SPONSORED
}

model ProfessionalProfile {
  id     String @id @default(cuid())
  userId String @unique
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  // Basic profile
  linkedInUrl String?
  countryCode String?
  language    AppLanguage?
  timeZone    String?

  // Professional details
  profession          String?
  industry            ProfessionalIndustry?
  currentRole         String?
  experienceRange     ExperienceRange?
  workLocation        String?
  professionalSummary String?

  // Skills and interests
  currentSkillLevel SkillLevel?
  targetSkillLevel  SkillLevel?

  terms ProfessionalProfileTerm[]

  // Learning preferences
  preferredLearningFormats LearningFormat[]          @default([])
  learningTimeCommitment   LearningTimeCommitment?
  learningBudgetPreference LearningBudgetPreference?

  // Legacy columns preserved for compatibility. They are backfilled into the
  // fields above and are no longer written by the professional profile module.
  interests String[]
  skills    String[]
  website   String?
  education String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([industry])
  @@index([countryCode])
}

// ========== Professional profile taxonomy ==========
enum ProfileTaxonomyKind {
  SKILL_AREA
  SUBJECT
}

enum ProfileTermUsage {
  MAIN_SKILL
  FAVORITE_SUBJECT
  SKILL_TO_IMPROVE
}

model ProfileTaxonomyTerm {
  id String @id @default(cuid())

  kind ProfileTaxonomyKind
  key  String

  label      String
  groupKey   String
  groupLabel String

  sortOrder Int     @default(0)
  isActive  Boolean @default(true)

  profileTerms ProfessionalProfileTerm[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([kind, key])
  @@index([kind, isActive])
  @@index([groupKey])
}

model ProfessionalProfileTerm {
  id String @id @default(cuid())

  profileId String
  profile   ProfessionalProfile @relation(fields: [profileId], references: [id], onDelete: Cascade)

  termId String
  term   ProfileTaxonomyTerm @relation(fields: [termId], references: [id], onDelete: Cascade)

  usage ProfileTermUsage

  createdAt DateTime @default(now())

  @@unique([profileId, termId, usage])
  @@index([profileId, usage])
  @@index([termId])
}

// ========== Professional credentials (general licences) ==========
model ProfessionalCredential {
  id String @id @default(cuid())

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  name                String
  issuingOrganization String
  licenceNumber       String?

  issueDate  DateTime
  expiryDate DateTime?

  annualCpdHours Float?

  pduTargetId String?
  pduTarget   PDUTarget? @relation(fields: [pduTargetId], references: [id], onDelete: SetNull)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
  @@index([pduTargetId])
  @@index([expiryDate])
}

model ProviderProfile {
  id String @id @default(cuid())

  userId String @unique
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  organizationName String?
  website          String?
  logoUrl          String?
  contactEmail     String?
  contactPhone     String?

  isPremium Boolean @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model OrganizationProfile {
  id String @id @default(cuid())

  userId String @unique
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  organizationName String
  website          String?
  logoUrl          String?
  contactEmail     String?
  contactPhone     String?

  industry    String?
  memberLimit Int?
  timezone    String?
  country     String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// ============== Org Access Request =============
enum OrganizationAccessRequestStatus {
  PENDING
  APPROVED
  REJECTED
}

enum OrganizationType {
  OTHER
  COMPANY
  UNIVERSITY
  GOVERNMENT
  NON_PROFIT
  ASSOCIATION
  TRAINING_PROVIDER
}

/// Carries an unmanaged partial unique index that Prisma cannot express:
/// "OrganizationAccessRequest_workEmail_pending_key" on (workEmail)
/// WHERE status = 'PENDING', added in migration
/// 20260720120000_org_access_request_pending_unique. It enforces one pending
/// request per work email while still allowing resubmission after a rejection.
/// `prisma migrate dev` will report it as drift and offer to drop it — do not
/// accept that; re-apply the index if it is ever lost.
model OrganizationAccessRequest {
  id String @id @default(cuid())

  representativeFullName        String
  organizationName              String
  workEmail                     String
  organizationType              OrganizationType
  representativeJobRole         String
  expectedLicensedProfessionals Int
  country                       String
  goals                         String

  status OrganizationAccessRequestStatus @default(PENDING)

  reviewedById String?
  reviewedBy   User?   @relation(fields: [reviewedById], references: [id], onDelete: SetNull)

  reviewedAt   DateTime?
  rejectReason String?

  approvedUserId String?

  notificationStatus       NotificationDeliveryStatus @default(NOT_REQUESTED)
  notificationSentAt       DateTime?
  notificationLastAttemptAt DateTime?
  notificationFailureCode  String?

  submissionNotificationStatus        NotificationDeliveryStatus @default(NOT_REQUESTED)
  submissionNotificationSentAt        DateTime?
  submissionNotificationLastAttemptAt DateTime?
  submissionNotificationFailureCode   String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([workEmail])
  @@index([status])
  @@index([organizationType])
  @@index([createdAt])
  @@index([notificationStatus])
  @@index([submissionNotificationStatus])
}

// ============== Course ===============
enum CourseCategory {
  CPD
  OTHER
  DESIGN
  FINANCE
  BUSINESS
  EDUCATION
  MARKETING
  TECHNOLOGY
  LEADERSHIP
  COMPLIANCE
  HEALTHCARE
  ENGINEERING
}

enum CourseLevel {
  BEGINNER
  ADVANCED
  ALL_LEVELS
  INTERMEDIATE
}

enum CourseStatus {
  DRAFT
  ARCHIVED
  PUBLISHED
}

enum CurriculumLessonType {
  QUIZ
  VIDEO
  ARTICLE
  DOWNLOAD
  ASSIGNMENT
  LIVE_SESSION
}

model Course {
  id   String @id @default(cuid())
  slug String @unique

  title       String
  instructor  String
  imageUrl    String?
  description String

  category CourseCategory
  level    CourseLevel    @default(ALL_LEVELS)
  status   CourseStatus   @default(DRAFT)

  price    Decimal? @db.Decimal(10, 2)
  currency String   @default("USD")
  isFree   Boolean  @default(true)

  durationMinutes Int?
  lastUpdatedAt   DateTime @default(now())

  requirements String[] @default([])
  learnings    String[] @default([])

  rating        Float @default(0)
  ratingCount   Int   @default(0)
  professionals Int   @default(0)

  isFeatured Boolean @default(false)

  providerId String?
  provider   User?   @relation("ProviderCourses", fields: [providerId], references: [id], onDelete: SetNull)

  curriculumSections      CurriculumSection[]
  organizationAssignments OrganizationAssignment[]

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  user                       User?                      @relation(fields: [userId], references: [id])
  userId                     String?
  externalLearningActivities ExternalLearningActivity[]

  @@index([status, category])
  @@index([status, level])
  @@index([providerId])
  @@index([createdAt])
  @@index([title])
}

model CurriculumSection {
  id String @id @default(cuid())

  courseId String
  course   Course @relation(fields: [courseId], references: [id], onDelete: Cascade)

  title       String
  description String?
  order       Int     @default(0)

  lessons CurriculumLesson[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([courseId, order])
  @@index([courseId])
  @@index([order])
}

model CurriculumLesson {
  id String @id @default(cuid())

  sectionId String
  section   CurriculumSection @relation(fields: [sectionId], references: [id], onDelete: Cascade)

  title           String
  description     String?
  type            CurriculumLessonType @default(VIDEO)
  durationMinutes Int?
  isPreview       Boolean              @default(false)
  order           Int                  @default(0)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([sectionId, order])
  @@index([sectionId])
  @@index([type])
  @@index([order])
}

// =============== Events =================
enum EventType {
  OTHER
  COURSE
  WEBINAR
  SEMINAR
  WORKSHOP
  TRAINING
  CONFERENCE
  NETWORKING
}

enum EventDeliveryMode {
  HYBRID
  RECORDED
  IN_PERSON
  LIVE_ONLINE
}

enum EventStatus {
  DRAFT
  ARCHIVED
  PUBLISHED
  CANCELLED
}

enum EventCategory {
  CPD
  OTHER
  DESIGN
  FINANCE
  BUSINESS
  EDUCATION
  MARKETING
  TECHNOLOGY
  HEALTHCARE
  LEADERSHIP
  COMPLIANCE
  ENGINEERING
}

enum EventRegistrationStatus {
  ATTENDED
  CANCELED
  COMPLETED
  CANCELLED
  REGISTERED
  NOT_ATTENDED
}

model Event {
  id   String @id @default(cuid())
  slug String @unique

  title        String
  type         EventType
  deliveryMode EventDeliveryMode
  category     EventCategory
  status       EventStatus       @default(DRAFT)

  imageUrl    String?
  speaker     String?
  organizer   String?
  description String

  startDate DateTime
  endDate   DateTime?
  timezone  String    @default("UTC")

  location  String?
  onlineUrl String?

  price    Decimal? @db.Decimal(10, 2)
  currency String   @default("USD")
  isFree   Boolean  @default(true)

  pdu       Float @default(0)
  capacity  Int?
  attendees Int   @default(0)
  views     Int   @default(0)

  rating        Float @default(0)
  averageRating Float @default(0)
  ratingCount   Int   @default(0)

  registrationEnabled Boolean @default(true)

  providerId String?
  provider   User?   @relation("ProviderEvents", fields: [providerId], references: [id], onDelete: SetNull)

  registrations EventRegistration[]

  createdAt     DateTime            @default(now())
  updatedAt     DateTime            @updatedAt
  deletedAt     DateTime?
  user          User?               @relation(fields: [userId], references: [id])
  userId        String?
  scheduleItems EventScheduleItem[]

  specificTopic     String?
  pduCategory       PDUCategory?
  earlyBirdDiscount Float?
  promotionVideoUrl String?

  language AppLanguage @default(EN)
  topic    String?

  thumbnailUrl        String?
  promotionalVideoUrl String?

  earlyBirdDiscountPercent Float?
  earlyBirdEndsAt          DateTime?

  promotionRequests          EventPromotionRequest[]
  organizationAssignments    OrganizationAssignment[]
  externalLearningActivities ExternalLearningActivity[]

  @@index([status, category])
  @@index([status, deliveryMode])
  @@index([providerId])
  @@index([startDate])
  @@index([createdAt])
  @@index([title])
  @@index([slug])
}

model EventRegistration {
  id String @id @default(cuid())

  eventId String
  event   Event  @relation(fields: [eventId], references: [id], onDelete: Cascade)

  userId String
  user   User   @relation("UserEventRegistrations", fields: [userId], references: [id], onDelete: Cascade)

  status      EventRegistrationStatus @default(REGISTERED)
  attendedAt  DateTime?
  completedAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([eventId, userId])
  @@index([userId])
  @@index([eventId])
  @@index([status])
}

model EventScheduleItem {
  id String @id @default(cuid())

  eventId String
  event   Event  @relation(fields: [eventId], references: [id], onDelete: Cascade)

  dayNumber   Int
  startTime   DateTime
  endTime     DateTime
  title       String
  description String?
  speaker     String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([eventId])
  @@index([dayNumber])
  @@index([startTime])
}

// ============== Calendar ================
enum CalendarEventType {
  COURSE
  WEBINAR
  MEETING
  EVENT
  TRAINING
  OTHER
}

model CalendarEvent {
  id String @id @default(cuid())

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  title           String
  type            CalendarEventType @default(OTHER)
  startDate       DateTime
  endDate         DateTime?
  durationMinutes Int?
  notes           String?

  contentType ContentType?
  contentId   String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
  @@index([startDate])
  @@index([contentType, contentId])
}

// ============== Podcast ================
enum PodcastCategory {
  AI
  CPD
  DATA
  OTHER
  CAREER
  DESIGN
  FINANCE
  BUSINESS
  EDUCATION
  MARKETING
  TECHNOLOGY
  HEALTHCARE
  LEADERSHIP
  COMPLIANCE
  ENGINEERING
}

enum PodcastStatus {
  DRAFT
  ARCHIVED
  PUBLISHED
}

model Podcast {
  id   String @id @default(cuid())
  slug String @unique

  title       String
  host        String
  imageUrl    String?
  description String

  category PodcastCategory
  status   PodcastStatus   @default(DRAFT)

  rating      Float @default(0)
  ratingCount Int   @default(0)
  listeners   Int   @default(0)

  durationMinutes Int?
  episodeCount    Int  @default(0)

  isFeatured Boolean @default(false)

  providerId String?
  provider   User?   @relation("ProviderPodcasts", fields: [providerId], references: [id], onDelete: SetNull)

  episodes PodcastEpisode[]

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  @@index([status, category])
  @@index([providerId])
  @@index([createdAt])
  @@index([title])
  @@index([slug])
}

model PodcastEpisode {
  id String @id @default(cuid())

  podcastId String
  podcast   Podcast @relation(fields: [podcastId], references: [id], onDelete: Cascade)

  title           String
  description     String?
  audioUrl        String?
  durationMinutes Int?
  episodeNumber   Int

  publishedAt DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@unique([podcastId, episodeNumber])
  @@index([podcastId])
  @@index([title])
}

// =============== YouTube ==================
enum YouTubeCategory {
  AI
  CPD
  DATA
  OTHER
  DESIGN
  CAREER
  FINANCE
  BUSINESS
  EDUCATION
  MARKETING
  TECHNOLOGY
  HEALTHCARE
  LEADERSHIP
  COMPLIANCE
  ENGINEERING
}

enum YouTubeChannelStatus {
  DRAFT
  ARCHIVED
  PUBLISHED
}

enum YouTubeVideoStatus {
  DRAFT
  ARCHIVED
  PUBLISHED
}

model YouTubeChannel {
  id   String @id @default(cuid())
  slug String @unique

  title       String
  description String?
  provider    String?
  imageUrl    String?
  channelUrl  String?

  subscribers Int @default(0)
  views       Int @default(0)
  videoCount  Int @default(0)

  category YouTubeCategory
  status   YouTubeChannelStatus @default(DRAFT)

  isFeatured Boolean @default(false)

  providerId   String?
  providerUser User?   @relation("ProviderYouTubeChannels", fields: [providerId], references: [id], onDelete: SetNull)

  videos YouTubeVideo[]

  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  deletedAt   DateTime?
  user        User?     @relation(fields: [userId], references: [id])
  userId      String?
  rating      Float     @default(0)
  ratingCount Int       @default(0)

  @@index([status, category])
  @@index([providerId])
  @@index([createdAt])
  @@index([title])
  @@index([slug])
}

model YouTubeVideo {
  id String @id @default(cuid())

  channelId String
  channel   YouTubeChannel @relation(fields: [channelId], references: [id], onDelete: Cascade)

  title        String
  description  String?
  thumbnailUrl String?
  videoUrl     String?

  durationMinutes Int?
  views           Int  @default(0)
  likes           Int  @default(0)

  status      YouTubeVideoStatus @default(PUBLISHED)
  publishedAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([channelId])
  @@index([status])
  @@index([title])
}

// ================= Content =================
enum ContentType {
  EVENT
  COURSE
  PODCAST
  YOUTUBE
}

enum ContentEnrollmentStatus {
  ACTIVE
  CANCELED
  COMPLETED
}

enum CartStatus {
  ACTIVE
  ABANDONED
  CHECKED_OUT
}

enum CartItemStatus {
  ACTIVE
  REMOVED
}

model WishlistItem {
  id     String @id @default(cuid())
  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  contentType ContentType
  contentId   String

  createdAt DateTime @default(now())

  @@unique([userId, contentType, contentId])
  @@index([userId])
  @@index([contentType, contentId])
}

model ContentEnrollment {
  id String @id @default(cuid())

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  contentType ContentType
  contentId   String

  status   ContentEnrollmentStatus @default(ACTIVE)
  progress Int                     @default(0)

  startedAt   DateTime  @default(now())
  completedAt DateTime?
  canceledAt  DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([userId, contentType, contentId])
  @@index([userId])
  @@index([contentType, contentId])
  @@index([status])
}

model ContentReview {
  id String @id @default(cuid())

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  contentType ContentType
  contentId   String

  rating  Int
  comment String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([userId, contentType, contentId])
  @@index([contentType, contentId])
  @@index([userId])
}

model Cart {
  id String @id @default(cuid())

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  status CartStatus @default(ACTIVE)

  items CartItem[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
  @@index([status])
}

model CartItem {
  id String @id @default(cuid())

  cartId String
  cart   Cart   @relation(fields: [cartId], references: [id], onDelete: Cascade)

  contentType ContentType
  contentId   String

  titleSnapshot String
  priceSnapshot Decimal @db.Decimal(10, 2)
  currency      String  @default("USD")

  status CartItemStatus @default(ACTIVE)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([cartId, contentType, contentId])
  @@index([cartId])
  @@index([contentType, contentId])
}

// =============== Provider =================
enum AppLanguage {
  EN
  FR
}

enum PDUCategory {
  OTHER
  ETHICS
  BUSINESS
  TECHNICAL
  STRATEGIC
  LEADERSHIP
  COMPLIANCE
  COMMUNICATION
